# =============================================================================
# PUBG Death Note Backend - 环境配置模板
# =============================================================================
# 使用说明：
# 1. 复制本文件为 .env：cp .env.example .env
# 2. 修改 .env 中的配置值（特别是 PUBG_API_KEY_1）
# 3. Docker 部署时，.env 文件需与 docker-compose.yml 放在同一目录
# =============================================================================

# -----------------------------------------------------------------------------
# 基础环境配置
# -----------------------------------------------------------------------------
# 运行环境：development（开发） / production（生产） / test（测试）
NODE_ENV=production

# 服务监听端口
PORT=3000

# 时区设置（影响日志时间、定时任务执行时间等）
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# PUBG 官方 API 配置
# -----------------------------------------------------------------------------
# 获取方式：https://developer.pubg.com/ 注册并创建应用
# 支持配置多个 Key，系统会自动轮询使用，提高请求并发能力
# 每个 Key 限制：每分钟 60 次请求，每秒 10 次请求
# 建议：至少配置 2-3 个 Key 以支持多用户并发处理

# PUBG API Key 1（必填，至少配置一个）
PUBG_API_KEY_1=your_api_key_here

# PUBG API Key 2（可选，取消注释并填入你的 Key）
# PUBG_API_KEY_2=

# PUBG API Key 3（可选）
# PUBG_API_KEY_3=

# API 区域：steam（Steam 平台） / kakao（Kakao 平台）
PUBG_API_REGION=steam

# API 请求超时时间（毫秒），超过此时间视为请求失败
PUBG_API_TIMEOUT=30000

# API 请求失败重试次数
PUBG_API_RETRY_COUNT=3

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
# 使用 SQLite 数据库，文件存储路径
# Docker 部署时建议使用容器内路径：file:/app/data/dev.db
# 本地开发时使用相对路径：file:./dev.db 或 file:../dev.db
DATABASE_URL=file:/app/data/dev.db

# 数据库最大连接数（SQLite 单文件数据库建议不超过 10）
DATABASE_MAX_CONNECTIONS=10

# -----------------------------------------------------------------------------
# 工作队列配置
# -----------------------------------------------------------------------------
# 并发处理对局数据的任务数量
# 数值越大处理越快，但会消耗更多 API 配额和系统资源
# 建议：单 Key 设为 3-5，多 Key 可适当提高
QUEUE_CONCURRENCY=5

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别：debug（调试） / info（信息） / warn（警告） / error（错误）
# 生产环境建议使用 info，调试问题时临时改为 debug
LOG_LEVEL=info

# 日志文件存储目录
# Docker 部署时建议使用：/app/logs
# 本地开发建议使用：./logs
LOG_DIR=/app/logs

# -----------------------------------------------------------------------------
# 速率限制配置（面向客户端 API 的保护机制）
# -----------------------------------------------------------------------------
# 速率限制时间窗口（秒）
RATE_LIMIT_TTL=60

# 每个 IP 在时间窗口内的最大请求数
# 超过此限制将返回 429 Too Many Requests
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# 缓存配置
# -----------------------------------------------------------------------------
# 缓存过期时间（秒），死亡笔记查询结果缓存时长
# 缓存可减少数据库查询压力，但数据会有延迟
CACHE_TTL=3600

# -----------------------------------------------------------------------------
# 安全配置
# -----------------------------------------------------------------------------
# CORS 允许的来源域名
# 生产环境建议设置为你的前端域名，如：https://yourdomain.com
# 多个域名用逗号分隔：https://a.com,https://b.com
# * 表示允许所有来源（仅限开发/测试环境）
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# 游戏数据目录配置（Docker 部署时通常不需要修改）
# -----------------------------------------------------------------------------
# 对局数据存储目录（包含对局详情和遥测数据）
GAME_DATA_DIR=./game-data
